---
// PLACEHOLDER FORM — replace the <form> action/method below with your real
// Brevo embed code when ready. See UPDATE-GUIDE.md, section "Connecting the
// email signup form to Brevo" for exact steps.
interface Props {
  heading?: string;
  subheading?: string;
  buttonLabel?: string;
}

const {
  heading = 'Get the Free AI Prompt Starter Pack for Catholic School Teachers',
  subheading = 'Practical, ready-to-use prompts for lesson planning, report cards, and parent emails — sent straight to your inbox.',
  buttonLabel = 'Send Me the Free Pack',
} = Astro.props;
---

<div class="email-signup card">
  <h3>{heading}</h3>
  <p class="muted">{subheading}</p>

  <form class="signup-form" data-placeholder-form="true" onsubmit="event.preventDefault(); this.querySelector('[data-status]').textContent = 'Thanks! (This is a placeholder form — connect Brevo to start collecting real emails.)';">
    <label class="visually-hidden" for="email-signup-input">Email address</label>
    <input
      id="email-signup-input"
      type="email"
      name="email"
      placeholder="Your email address"
      required
    />
    <button type="submit" class="btn btn--primary">{buttonLabel}</button>
  </form>
  <p data-status class="form-status muted"></p>
  <p class="placeholder-note">Placeholder form — not yet connected to an email service.</p>
</div>

<style>
  .email-signup h3 { margin-bottom: 0.4rem; }
  .signup-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }
  .signup-form input {
    padding: 0.8rem 1rem;
    border: 1px solid var(--color-warm-gray-300);
    border-radius: var(--radius);
    font-size: 1rem;
    font-family: var(--font-body);
  }
  .signup-form input:focus {
    outline: 2px solid var(--color-burgundy);
    outline-offset: 1px;
  }
  @media (min-width: 540px) {
    .signup-form { flex-direction: row; }
    .signup-form input { flex: 1; }
  }
  .form-status { min-height: 1.2em; font-size: 0.9rem; }
</style>
