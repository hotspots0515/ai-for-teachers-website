---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about/', label: 'About' },
  { href: '/free-resource/', label: 'Free Resource' },
  { href: '/shop/', label: 'Shop' },
  { href: '/newsletter/', label: 'Newsletter' },
];

const collectionsLinks = [
  { href: '/collections/', label: 'All Collections' },
  { href: '/collections/readings/', label: 'Readings for the Day' },
  { href: '/collections/saints/', label: 'Saints' },
  { href: '/collections/liturgical-calendar/', label: 'Liturgical Calendar' },
  { href: '/collections/sacraments/', label: 'Sacraments' },
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand">AI for Teachers</a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle" />
    <label for="nav-toggle" class="nav-toggle-label" aria-label="Toggle menu">
      <span></span>
    </label>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {navLinks.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
        <li class="has-dropdown">
          <a href="/collections/">Collections</a>
          <ul class="dropdown">
            {collectionsLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </li>
      </ul>
      <a href="/free-resource/" class="btn btn--primary btn--nav">Subscribe</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--color-warm-white);
    border-bottom: 1px solid var(--color-warm-gray-300);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
    flex-wrap: wrap;
    position: relative;
  }

  .brand {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1.35rem;
    color: var(--color-burgundy);
    text-decoration: none;
  }

  .nav-toggle { display: none; }
  .nav-toggle-label {
    display: flex;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
  }
  .nav-toggle-label span,
  .nav-toggle-label::before,
  .nav-toggle-label::after {
    content: '';
    display: block;
    width: 26px;
    height: 2.5px;
    background: var(--color-ink);
    border-radius: 2px;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .site-nav ul {
    list-style: none;
    display: flex;
    gap: 1.4rem;
    margin: 0;
    padding: 0;
  }

  .site-nav a {
    text-decoration: none;
    color: var(--color-ink);
    font-weight: 500;
    font-size: 0.97rem;
  }

  .site-nav a:hover { color: var(--color-burgundy); }

  .has-dropdown { position: relative; }
  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: var(--color-warm-white);
    border: 1px solid var(--color-warm-gray-300);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
    padding: 0.5rem 0;
    min-width: 220px;
    flex-direction: column;
    gap: 0;
  }
  .has-dropdown:hover .dropdown,
  .has-dropdown:focus-within .dropdown {
    display: flex;
  }
  .dropdown li { padding: 0; }
  .dropdown a {
    display: block;
    padding: 0.55rem 1rem;
    white-space: nowrap;
  }
  .dropdown a:hover { background: var(--color-cream); }

  .btn--nav {
    padding: 0.55rem 1.2rem;
    font-size: 0.95rem;
  }

  @media (max-width: 860px) {
    .nav-toggle-label { display: flex; }

    .site-nav {
      display: none;
      width: 100%;
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
      order: 3;
      padding-top: 1rem;
    }

    .site-nav ul {
      flex-direction: column;
      width: 100%;
      gap: 0;
    }

    .site-nav ul li { width: 100%; }
    .site-nav ul li a { display: block; padding: 0.6rem 0; }

    .has-dropdown .dropdown {
      display: flex;
      position: static;
      border: none;
      box-shadow: none;
      padding-left: 1rem;
    }

    .nav-toggle:checked ~ .site-nav {
      display: flex;
    }
  }
</style>
